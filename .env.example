# Pexels API key for pfp generation (https://www.pexels.com/api/)
# Without this, the daemon falls back to a procedural flower image.
PEXELS_API_KEY=

# Supabase relay config for Phase 2.
# Never expose SUPABASE_SERVICE_ROLE_KEY or SUPABASE_JWT_SECRET in browser/client env.
SUPABASE_URL=
SUPABASE_REST_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional daemon polling interval for autonomous Supabase sync.
TEAMBRIDGE_RELAY_SYNC_INTERVAL_MS=5000

# Optional local CLI convenience only; prefer passing login flags in shared shells.
TEAMBRIDGE_EMAIL=
TEAMBRIDGE_PASSWORD=
