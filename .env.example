# Pexels API key for pfp generation (https://www.pexels.com/api/)
# Without this, the daemon falls back to a procedural flower image.
PEXELS_API_KEY=

# Supabase relay config for Phase 2.
# Never expose SUPABASE_SERVICE_ROLE_KEY or SUPABASE_JWT_SECRET in browser/client env.
SUPABASE_URL=
SUPABASE_REST_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
